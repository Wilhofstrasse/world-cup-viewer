<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchAgent for the Node SRF proxy.
  Install (one-time):
    cp tools/srf-proxy/com.filipeandrade.srf-proxy.plist ~/Library/LaunchAgents/
    launchctl load   ~/Library/LaunchAgents/com.filipeandrade.srf-proxy.plist
    launchctl start  com.filipeandrade.srf-proxy
  Check:
    launchctl list | grep srf-proxy
    curl -s http://127.0.0.1:8791/health
  Logs:
    tail -f /Users/filipeandrade/Library/Logs/srf-proxy.log
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.filipeandrade.srf-proxy</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/filipeandrade/Developer/world-cup-viewer/tools/srf-proxy/server.mjs</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>SRF_PROXY_PORT</key><string>8791</string>
    <key>SRF_PROXY_PUBLIC_BASE</key><string>https://srf.filipeandrade.com</string>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/Users/filipeandrade/Library/Logs/srf-proxy.log</string>
  <key>StandardErrorPath</key><string>/Users/filipeandrade/Library/Logs/srf-proxy.log</string>
  <key>WorkingDirectory</key><string>/Users/filipeandrade/Developer/world-cup-viewer/tools/srf-proxy</string>
</dict>
</plist>
